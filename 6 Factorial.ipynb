   "source": [
    "def factorial(num):\n",
    "    if(type(num) != int):\n",
    "        return None\n",
    "        \n",
    "    if num < 0:\n",
    "        return None\n",
    "        \n",
    "\n",
    "    if num == 1 or num == 0:\n",
    "        return 1\n",
    "        \n",
    "    \n",
    "    return num * factorial(num-1)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "print(factorial(3))"
   ]
  },
