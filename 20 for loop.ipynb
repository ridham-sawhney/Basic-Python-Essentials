   "source": [
    "for num in range(2,100):\n",
    "    for factor in range(2,int(num**0.5)+1):\n",
    "        if num%factor ==0:\n",
    "            break\n",
    "    else:\n",
    "        print(f'{num} is a prime number')"
   ]
